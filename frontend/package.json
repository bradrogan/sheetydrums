{
  "name": "sheetydrums-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "VexFlow-based renderer for sheetydrums events.json",
  "scripts": {
    "schema:gen": "json2ts -i ../schema/events.schema.json -o src/generated/events.d.ts --no-additionalProperties",
    "typecheck": "tsc --noEmit",
    "dev": "vite",
    "prebuild": "pnpm run schema:gen && pnpm run typecheck",
    "build": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "vexflow": "^5.0.0"
  },
  "devDependencies": {
    "json-schema-to-typescript": "^15.0.4",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
